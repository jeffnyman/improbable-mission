{
  "name": "improbable-mission",
  "version": "0.0.0",
  "license": "MIT",
  "author": {
    "name": "Jeff Nyman",
    "email": "jeffnyman@gmail.com",
    "url": "https://testerstories.com"
  },
  "description": "A faithful recreation of the 1984 puzzle-platformer Impossible Mission by Epyx.",
  "keywords": [
    "commodore 64",
    "retrogaming",
    "recreation",
    "platformer",
    "game"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffnyman/improbable-mission/"
  },
  "bugs": {
    "url": "https://github.com/jeffnyman/improbable-mission/issues"
  },
  "homepage": "https://jeffnyman.github.io/improbable-mission",
  "scripts": {
    "dev": "vite --host --open",
    "build": "vite build",
    "preview": "vite preview --host --open",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,cjs,mjs}": [
      "eslint . --quiet --fix"
    ],
    "*.{json,js,cjs,mjs}": [
      "prettier --write --ignore-unknown ."
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "prettier": "3.6.2",
    "vite": "^7.1.7"
  }
}
