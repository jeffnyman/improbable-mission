  },
  "homepage": "https://jeffnyman.github.io/improbable-mission",
  "scripts": {
    "dev": "vite --host --open",
    "build": "tsc && vite build",
    "preview": "vite preview --host --open",
    "check": "tsc --noEmit && eslint . && stylelint ./**/*.css && prettier . --check",
    "fix": "eslint --fix . && stylelint ./**/*.css --fix && prettier . --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "3.6.2",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0",
    "vite": "^7.2.4",
    "vite-plugin-checker": "^0.11.0"
  }
}
