{
  "name": "improbable-mission",
  "private": true,
  "type": "module",
  "version": "0.3.0",
  "license": "MIT",
  "author": {
    "name": "Jeff Nyman",
    "email": "jeffnyman@gmail.com",
    "url": "https://testerstories.com"
  },
  "description": "A faithful recreation of the 1984 puzzle-platformer Impossible Mission by Epyx.",
  "keywords": [
    "commodore 64",
    "c64",
    "retrogaming",
    "recreation",
    "platformer",
    "game",
    "impossible mission",
    "epyx",
    "typescript",
    "javascript"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffnyman/improbable-mission/"
  },
  "bugs": {
    "email": "jeffnyman@gmail.com",
    "url": "https://github.com/jeffnyman/improbable-mission/issues"
  },
  "homepage": "https://jeffnyman.github.io/improbable-mission",
  "scripts": {
    "dev": "vite --host --open",
    "build": "tsc && vite build",
    "preview": "vite preview --host --open",
    "check": "tsc --noEmit && eslint . && stylelint ./**/*.css && prettier . --check",
    "fix": "eslint --fix . && stylelint ./**/*.css --fix && prettier . --write",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,js}": [
      "eslint --quiet --max-warnings=0 --fix --cache --cache-location .eslintcache"
    ],
    "**/*.{css,md,json}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.39.1",
    "@release-it/conventional-changelog": "^10.0.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "3.6.2",
    "release-it": "^19.0.6",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0",
    "vite": "^7.2.4",
    "vite-plugin-checker": "^0.11.0",
    "vite-plugin-webfont-dl": "^3.11.1"
  }
}
